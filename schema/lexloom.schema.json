{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "LexLoom Universal Syntax Schema",
    "description": "Defines language syntax rules for multi-platform generation (VS Code, Vim, Notepad++).",
    "type": "object",
    "required": [
        "metadata",
        "rules"
    ],
    "properties": {
        "metadata": {
            "type": "object",
            "description": "Information about the language being generated.",
            "required": [
                "name",
                "scopeName",
                "extensions"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Human readable name of the language (e.g., 'My Custom Language')."
                },
                "scopeName": {
                    "type": "string",
                    "pattern": "^source\\..+$",
                    "description": "Top-level TextMate scope. Must start with 'source.' (e.g., 'source.my-custom-language')."
                },
                "extensions": {
                    "type": "array",
                    "description": "List of file extensions associated with this language (e.g., ['.mycustomlanguage']).",
                    "items": {
                        "type": "string",
                        "pattern": "^\\..+$"
                    }
                },
                "version": {
                    "type": "string",
                    "description": "Version of the generated syntax package (e.g., '1.0.0').",
                    "default": "1.0.0"
                }
            }
        },
        "rules": {
            "type": "array",
            "description": "The list of syntax rules that define how the language is highlighted.",
            "items": {
                "type": "object",
                "required": [
                    "ruleType",
                    "universalScope"
                ],
                "properties": {
                    "universalScope": {
                        "type": "string",
                        "description": "The standardized scope mapping. LexLoom will gracefully degrade this for editors like Vim and Notepad++.",
                        "oneOf": [
                            {
                                "const": "keyword.control",
                                "description": "Words that control the flow of execution (e.g., if, else, for, while, return, action, extend)."
                            },
                            {
                                "const": "keyword.operator",
                                "description": "Mathematical, logical, and assignment operators (e.g., +, -, *, ==, &&, =)."
                            },
                            {
                                "const": "keyword.other",
                                "description": "Modifiers and other structural keywords that don't control flow (e.g., static, virtual, const)."
                            },
                            {
                                "const": "support.type",
                                "description": "Built-in, primitive data types provided natively by the language (e.g., int, float, bool, string)."
                            },
                            {
                                "const": "entity.name.type",
                                "description": "Custom, user-defined types, classes, structs, or interfaces (e.g., MyClass, UserProfile)."
                            },
                            {
                                "const": "entity.name.function",
                                "description": "The names of functions or methods when they are declared or invoked (e.g., calculateTotal, print)."
                            },
                            {
                                "const": "variable.other",
                                "description": "Standard variables or identifiers used throughout the code (e.g., myVar, counter)."
                            },
                            {
                                "const": "variable.parameter",
                                "description": "Specific variables passed as arguments inside a function or method signature (e.g., x and y in add(x, y))."
                            },
                            {
                                "const": "constant.numeric",
                                "description": "Numbers, including decimals, hex, binary, and floats (e.g., 42, 3.14, 0xFF)."
                            },
                            {
                                "const": "constant.language",
                                "description": "Built-in, immutable language constants that act like primitives (e.g., true, false, null)."
                            },
                            {
                                "const": "string.quoted.double",
                                "description": "Standard strings wrapped in double quotes (e.g., \"Hello World\")."
                            },
                            {
                                "const": "string.quoted.single",
                                "description": "Strings or characters wrapped in single quotes (e.g., 'Hello' or 'A')."
                            },
                            {
                                "const": "string.quoted.triple",
                                "description": "Multi-line block strings, often used for documentation or raw text (e.g., \"\"\"Multi-line string\"\"\")."
                            },
                            {
                                "const": "comment.line",
                                "description": "Single-line comments (e.g., // This is a comment)."
                            },
                            {
                                "const": "comment.block",
                                "description": "Multi-line comments (e.g., /* This is a block comment */)."
                            }
                        ]
                    },
                    "ruleType": {
                        "type": "string",
                        "description": "The intent-based rule logic to apply.",
                        "oneOf": [
                            {
                                "const": "wordList",
                                "description": "A list of whole words to match (e.g., keywords). Handles word boundaries automatically."
                            },
                            {
                                "const": "symbolList",
                                "description": "A list of literal symbols or operators (e.g., +, ==). Handles regex escaping automatically."
                            },
                            {
                                "const": "preset",
                                "description": "Use a pre-defined, highly optimized regex pattern for common constructs like numbers."
                            },
                            {
                                "const": "lineMarker",
                                "description": "Matches a single-line construct starting with a specific marker (e.g., single-line comments)."
                            },
                            {
                                "const": "blockMarker",
                                "description": "Matches a multi-line region between a start and end marker (e.g., block comments)."
                            },
                            {
                                "const": "stringMarker",
                                "description": "Matches a quoted string with optional escape character and language injection support."
                            }
                        ]
                    }
                },
                "allOf": [
                    {
                        "if": {
                            "properties": {
                                "ruleType": {
                                    "const": "wordList"
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "words"
                            ],
                            "properties": {
                                "words": {
                                    "type": "array",
                                    "description": "Exact words to match. The engine handles word boundaries automatically.",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "ruleType": {
                                    "const": "symbolList"
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "symbols"
                            ],
                            "properties": {
                                "symbols": {
                                    "type": "array",
                                    "description": "Literal operators or symbols. The engine will safely escape these for regex.",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "ruleType": {
                                    "const": "preset"
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "presetId"
                            ],
                            "properties": {
                                "presetId": {
                                    "type": "string",
                                    "description": "Select a built-in highly optimized regex pattern.",
                                    "oneOf": [
                                        {
                                            "const": "number.decimal",
                                            "description": "Standard integer or floating-point numbers in base 10."
                                        },
                                        {
                                            "const": "number.hex",
                                            "description": "Hexadecimal numbers starting with 0x or 0X (e.g., 0xFFAD)."
                                        },
                                        {
                                            "const": "number.binary",
                                            "description": "Binary numbers starting with 0b or 0B (e.g., 0b1010)."
                                        },
                                        {
                                            "const": "number.octal",
                                            "description": "Octal numbers starting with 0 or 0o (e.g., 0755)."
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "ruleType": {
                                    "const": "lineMarker"
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "start"
                            ],
                            "properties": {
                                "start": {
                                    "type": "string",
                                    "description": "The literal characters that start the line comment (e.g., '//')."
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "ruleType": {
                                    "const": "blockMarker"
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "start",
                                "end"
                            ],
                            "properties": {
                                "start": {
                                    "type": "string",
                                    "description": "Starting characters (e.g., '/*')."
                                },
                                "end": {
                                    "type": "string",
                                    "description": "Ending characters (e.g., '*/')."
                                },
                                "injectLanguage": {
                                    "$ref": "#/definitions/injectLanguage"
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "ruleType": {
                                    "const": "stringMarker"
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "quote"
                            ],
                            "properties": {
                                "quote": {
                                    "type": "string",
                                    "description": "The literal quotation mark (e.g., '\"' or '\"\"\"')."
                                },
                                "escapeChar": {
                                    "type": "string",
                                    "description": "The character used to escape quotes inside the string (e.g., '\\')."
                                },
                                "injectLanguage": {
                                    "$ref": "#/definitions/injectLanguage"
                                }
                            }
                        }
                    }
                ]
            }
        }
    },
    "definitions": {
        "injectLanguage": {
            "type": "object",
            "description": "Embeds another language's syntax highlighting inside this region.",
            "required": [
                "textmateScope",
                "vimSyntax"
            ],
            "properties": {
                "textmateScope": {
                    "type": "string",
                    "description": "The VS Code/TextMate scope to inject (e.g., 'source.c')."
                },
                "vimSyntax": {
                    "type": "string",
                    "description": "The Vim syntax file to include (e.g., 'c')."
                }
            }
        }
    }
}